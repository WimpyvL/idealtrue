{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information, including referral data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "role": { "type": "string", "enum": ["host", "guest", "admin"], "description": "The user's role in the system." },
        "referralCode": { "type": "string", "description": "The user's unique referral code." },
        "referredBy": { "type": "string", "description": "The UID of the user who referred this user." },
        "balance": { "type": "number", "description": "The user's current referral earnings balance." },
        "referralCount": { "type": "number", "description": "Total number of successful referrals." },
        "tier": { "type": "string", "enum": ["bronze", "silver", "gold"], "description": "The user's referral tier." },
        "host_plan": { "type": "string", "enum": ["free", "standard", "professional", "premium"], "description": "The user's host subscription plan." },
        "kycStatus": { "type": "string", "enum": ["none", "pending", "verified", "rejected"], "description": "The user's KYC verification status." },
        "kycData": {
          "type": "object",
          "properties": {
            "idNumber": { "type": "string" },
            "idType": { "type": "string", "enum": ["id_card", "passport", "drivers_license"] },
            "idImage": { "type": "string" },
            "selfieImage": { "type": "string" },
            "submittedAt": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role", "referralCode"]
    },
    "Listing": {
      "title": "Accommodation Listing",
      "description": "Represents a property listed for holiday accommodation.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the listing." },
        "hostUid": { "type": "string", "description": "The UID of the host who owns the listing." },
        "title": { "type": "string", "description": "The title of the listing." },
        "description": { "type": "string", "description": "A detailed description of the property." },
        "location": { "type": "string", "description": "The physical location of the property." },
        "pricePerNight": { "type": "number", "description": "The price per night for the accommodation." },
        "images": { "type": "array", "items": { "type": "string" }, "description": "A list of image URLs for the listing." },
        "amenities": { "type": "array", "items": { "type": "string" }, "description": "A list of amenities available at the property." },
        "status": { "type": "string", "enum": ["active", "inactive", "pending"], "description": "The current status of the listing." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the listing was created." }
      },
      "required": ["hostUid", "title", "description", "location", "pricePerNight", "status"]
    },
    "Booking": {
      "title": "Accommodation Booking",
      "description": "Represents a booking made by a guest for a listing.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the booking." },
        "listingId": { "type": "string", "description": "The ID of the listing being booked." },
        "guestUid": { "type": "string", "description": "The UID of the guest making the booking." },
        "hostUid": { "type": "string", "description": "The UID of the host who owns the listing." },
        "checkIn": { "type": "string", "format": "date-time", "description": "The check-in date." },
        "checkOut": { "type": "string", "format": "date-time", "description": "The check-out date." },
        "totalPrice": { "type": "number", "description": "The total price for the booking." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"], "description": "The current status of the booking." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was created." }
      },
      "required": ["listingId", "guestUid", "hostUid", "checkIn", "checkOut", "totalPrice", "status"]
    },
    "SocialPost": {
      "title": "AI Generated Social Media Post",
      "description": "A social media post generated by AI for a listing.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the post." },
        "listingId": { "type": "string", "description": "The ID of the listing the post is for." },
        "hostUid": { "type": "string", "description": "The UID of the host who generated the post." },
        "platform": { "type": "string", "enum": ["instagram", "facebook", "twitter", "linkedin"], "description": "The target social media platform." },
        "content": { "type": "string", "description": "The generated text content for the post." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the post was generated." }
      },
      "required": ["listingId", "hostUid", "platform", "content"]
    },
    "Referral": {
      "title": "Referral Record",
      "description": "A record of a successful referral and the reward earned.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the referral record." },
        "referrerUid": { "type": "string", "description": "The UID of the user who made the referral." },
        "referredUid": { "type": "string", "description": "The UID of the user who was referred." },
        "amount": { "type": "number", "description": "The reward amount earned from this referral." },
        "type": { "type": "string", "enum": ["signup", "booking"], "description": "The type of action that triggered the reward." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the referral reward was recorded." }
      },
      "required": ["referrerUid", "referredUid", "amount", "type"]
    },
    "Review": {
      "title": "User Review",
      "description": "A review left by a guest for a listing.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the review." },
        "listingId": { "type": "string", "description": "The ID of the listing being reviewed." },
        "guestUid": { "type": "string", "description": "The UID of the guest who left the review." },
        "hostUid": { "type": "string", "description": "The UID of the host who owns the listing." },
        "cleanliness": { "type": "integer", "description": "Rating for cleanliness (1-5)." },
        "accuracy": { "type": "integer", "description": "Rating for accuracy (1-5)." },
        "communication": { "type": "integer", "description": "Rating for communication (1-5)." },
        "location": { "type": "integer", "description": "Rating for location (1-5)." },
        "value": { "type": "integer", "description": "Rating for value (1-5)." },
        "comment": { "type": "string", "description": "Written review comment." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was created." }
      },
      "required": ["listingId", "guestUid", "hostUid", "cleanliness", "accuracy", "communication", "location", "value"]
    },
    "Subscription": {
      "title": "Host Subscription",
      "description": "A record of a host's subscription payment.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the subscription record." },
        "hostUid": { "type": "string", "description": "The UID of the host who paid for the subscription." },
        "plan": { "type": "string", "enum": ["standard", "professional", "premium"], "description": "The subscription plan purchased." },
        "amount": { "type": "number", "description": "The amount paid for the subscription." },
        "status": { "type": "string", "enum": ["active", "expired", "cancelled"], "description": "The current status of the subscription." },
        "startDate": { "type": "string", "format": "date-time", "description": "When the subscription started." },
        "endDate": { "type": "string", "format": "date-time", "description": "When the subscription expires." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the subscription record was created." }
      },
      "required": ["hostUid", "plan", "amount", "status", "startDate", "endDate"]
    },
    "Notification": {
      "title": "Platform Notification",
      "description": "A notification sent to users by the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "success", "error"] },
        "target": { "type": "string", "enum": ["all", "hosts", "guests"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "target"]
    },
    "PlatformSettings": {
      "title": "Platform Global Settings",
      "description": "Global configuration for the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "enum": ["global"] },
        "referralRewardAmount": { "type": "number" },
        "commissionRate": { "type": "number" },
        "minWithdrawalAmount": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referralRewardAmount", "commissionRate", "minWithdrawalAmount"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles." },
    "/listings/{listingId}": { "schema": "Listing", "description": "Property listings." },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Accommodation bookings." },
    "/socialPosts/{postId}": { "schema": "SocialPost", "description": "AI generated social media posts." },
    "/referrals/{referralId}": { "schema": "Referral", "description": "Referral reward records." },
    "/reviews/{reviewId}": { "schema": "Review", "description": "User reviews." },
    "/subscriptions/{subscriptionId}": { "schema": "Subscription", "description": "Host subscription records." },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "Platform notifications." },
    "/settings/{settingsId}": { "schema": "PlatformSettings", "description": "Global platform settings." }
  }
}
