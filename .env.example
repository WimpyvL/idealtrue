# Optional local overrides
DISABLE_HMR="false"

# Default frontend behavior should point at a local Encore backend.
# Only override this when you explicitly want to target a remote environment.
VITE_ENCORE_API_URL="http://127.0.0.1:4000"

# Development-only auth escape hatch. Never enable this outside true local development.
# IDEAL_STAY_ENABLE_DEV_LOGIN="true"

# Backend runtime config
# Set these in Encore secrets or environment config for the backend service:
# YOCO_SECRET_KEY
# YOCO_WEBHOOK_SECRET
# AUTH_TOKEN_SECRET
# IDEAL_STAY_APP_URL
# RESEND_API_KEY
# AUTH_EMAIL_FROM
# AUTH_EMAIL_REPLY_TO
