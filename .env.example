# Optional local overrides
DISABLE_HMR="false"

# Local dev proxy target. The app now talks to Encore through a same-origin proxy and
# stores the session in an HttpOnly cookie. For local development the Express dev server
# falls back to http://127.0.0.1:4000 if this is unset, but setting it explicitly is clearer.
ENCORE_API_URL="http://127.0.0.1:4000"

# Vercel preview/production must set ENCORE_API_URL explicitly.
# Do not point production at a staging Encore backend.
# If you intentionally need that temporary fallback, set:
# ALLOW_STAGING_ENCORE_BACKEND="true"

# Gemini powers the trip planner chat, review summaries, and social content/image generation.
# Set this in both Vercel env vars and Encore runtime config:
# GEMINI_API_KEY
# Optional model overrides:
# GEMINI_TEXT_MODEL="gemini-2.5-flash"
# GEMINI_IMAGE_MODEL="gemini-2.5-flash-image-preview"

# Development-only auth escape hatch. Never enable this outside true local development.
# IDEAL_STAY_ENABLE_DEV_LOGIN="true"

# Backend runtime config
# Set these in Encore secrets or environment config for the backend service:
# YOCO_SECRET_KEY
# YOCO_WEBHOOK_SECRET
# AUTH_TOKEN_SECRET
# IDEAL_STAY_APP_URL
# RESEND_API_KEY
# AUTH_EMAIL_FROM
# AUTH_EMAIL_REPLY_TO
# GEMINI_API_KEY
