{
  "name": "ideal-stay",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --eval \"import { join } from 'node:path'; import { pathToFileURL } from 'node:url'; import(pathToFileURL(join(process.cwd().replace(/^\\\\\\\\\\?\\\\/, ''), 'server.ts')).href);\"",
    "check:config": "node scripts/check-production-config.mjs",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:unit": "tsx --test tests/*.test.ts",
    "test:ui": "vitest run",
    "test:e2e": "playwright test",
    "seed:demo": "node scripts/seed-demo-data.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.2"
  }
}
